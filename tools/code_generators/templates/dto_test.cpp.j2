// Тест: проверка isValid
BOOST_AUTO_TEST_CASE(Validation)
{
    {{ dto.name }} dto;

    // Проверка наличия обязательных полей
    bool hasRequiredFields = false;

    {% for field in dto.fields %}
    {% if field.required and not field.const_value %}
    hasRequiredFields = true;
    {% endif %}
    {% endfor %}

    {% set has_required = false %}
    {% for field in dto.fields %}
    {% if field.required and not field.const_value %}
        {% if not has_required %}
    // Изначально обязательные поля пусты/невалидны -- значение DTO должно быть невалидным.
    BOOST_TEST(!dto.isValid());
            {% set has_required = true %}
        {% endif %}
    // Задаём обязательное поле: {{ field.name_camel }}
    {% if field.cpp_type == 'std::string' %}
    dto.set{{ field.name_pascal }}("test_{{ field.name_snake }}");
    {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    dto.set{{ field.name_pascal }}(42);
    {% elif field.cpp_type == 'bool' %}
    dto.set{{ field.name_pascal }}(true);
    {% elif field.cpp_type in ['double', 'float'] %}
    dto.set{{ field.name_pascal }}(3.14);
    {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    dto.set{{ field.name_pascal }}(secondsToTimePoint(1640995200));
    {% elif field.cpp_type.startswith('std::vector<') %}
    dto.set{{ field.name_pascal }}({"item1"});
    {% endif %}
    {% endif %}
    {% endfor %}

    {% if has_required %}
    // После назначения всех обязательных полей значение DTO должно быть валидным
    BOOST_TEST(dto.isValid());
    {% else %}
    // Обязательных полей нет, DTO должен быть валидным по умолчанию
    BOOST_TEST(dto.isValid());
    {% endif %}
}

// Тест: Операторы сравнения
BOOST_AUTO_TEST_CASE(ComparisonOperators)
{
    {{ dto.name }} dto1;
    {{ dto.name }} dto2;

    // Изначально они должны быть равны (оба созданы по умолчанию)
    BOOST_TEST(dto1 == dto2);
    BOOST_TEST(!(dto1 != dto2));

    {% set tested = false %}
    {% for field in dto.fields %}
        {% if not tested and not field.const_value and field.required %}
        // Изменим поле, чтобы сделать их разными
        {% if field.cpp_type == 'std::string' %}
    dto1.set{{ field.name_pascal }}("different_value");
    BOOST_TEST(dto1 != dto2);
    BOOST_TEST(!(dto1 == dto2));
        {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    dto1.set{{ field.name_pascal }}(999);
    BOOST_TEST(dto1 != dto2);
    BOOST_TEST(!(dto1 == dto2));
        {% elif field.cpp_type == 'bool' %}
    dto1.set{{ field.name_pascal }}(!dto1.{{ field.name_camel }}());
    BOOST_TEST(dto1 != dto2);
    BOOST_TEST(!(dto1 == dto2));
        {% elif field.cpp_type in ['double', 'float'] %}
    dto1.set{{ field.name_pascal }}(999.99);
    BOOST_TEST(dto1 != dto2);
    BOOST_TEST(!(dto1 == dto2));
        {% elif field.cpp_type.startswith('std::vector<') %}
    dto1.set{{ field.name_pascal }}({"different"});
    BOOST_TEST(dto1 != dto2);
    BOOST_TEST(!(dto1 == dto2));
        {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    dto1.set{{ field.name_pascal }}(secondsToTimePoint(1735689600));
    BOOST_TEST(dto1 != dto2);
    BOOST_TEST(!(dto1 == dto2));
        {% endif %}
        {% set tested = true %}
        {% endif %}
    {% endfor %}
}

